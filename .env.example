# Redis

REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Storage
STORAGE_PATH=storage/jobs

# OpenAI
OPENAI_API_KEY=sk-...
TTS_MODEL=tts-1
OCR_MODEL=gpt-4o

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# MinIO Buckets (create these in MinIO console)
MINIO_BUCKET_BACKGROUNDS=qa-backgrounds
MINIO_BUCKET_GIFS=qa-meme-gifs
MINIO_BUCKET_SOUNDS=qa-sounds

# Video settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
TRANSITION_DURATION=2.0
BACKGROUND_AUDIO_VOLUME=0.3

# Job expiry
FILE_EXPIRY_HOURS=24
